{
  "name": "web-ide-electron",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone Electron IDE with native filesystem and Judge0-inspired local execution engine",
  "main": "main.js",
  "author": "Himanshuorz",
  "repository": {
    "type": "git",
    "url": "https://github.com/Himanshuorz/IDE_WEB.git"
  },
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "dist": "electron-builder --win --x64 --publish=never",
    "dist:dir": "electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "codemirror": "^5.65.16"
  },
  "devDependencies": {
    "electron": "^31.0.2",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.himanshuorz.webide",
    "productName": "WebIDE",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "engine/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ]
    }
  }
}
